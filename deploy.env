# Render deployment env for https://redarcx.onrender.com
# Copy these into your Render service Environment settings.

# Public app URL / reverse proxy
REDARC_API=https://redarcx.onrender.com/api
REDARC_FE_API=https://redarcx.onrender.com/api
SERVER_NAME=redarcx.onrender.com

# Runtime
API_PORT=18000
API_UPSTREAM=http://127.0.0.1:18000
GUNICORN_TIMEOUT=600
GUNICORN_GRACEFUL_TIMEOUT=30
UPLOAD_MAX_BYTES=1073741824
ADMIN_DELETE_MAX_ROWS=100000

# Auth
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
INGEST_PASSWORD=CHANGE_ME_INGEST_PASSWORD

# Feature flags (fast demo mode)
DEMO=true
SEARCH_ENABLED=true
INGEST_ENABLED=false
INDEX_ENABLED=false
DOWNLOAD_IMAGES=false

# Optional media path
IMAGE_PATH=/var/data/redarc-images

# ---------- Optional: full Postgres mode ----------
# Set DEMO=false and configure DB variables below.
# PG_DSN=
# PGFTS_DSN=
# PGFTS_URL=
# DATABASE_URL_FTS=
# PG_DATABASE=postgres
# PG_USER=postgres
# PG_PASSWORD=
# PG_HOST=
# PG_PORT=5432
# PGFTS_DATABASE=postgres
# PGFTS_USER=postgres
# PGFTS_PASSWORD=
# PGFTS_HOST=
# PGFTS_PORT=5432

# ---------- Optional: Redis / ingest workers ----------
# REDIS_HOST=
# REDIS_PORT=6379
# CLIENT_ID=
# CLIENT_SECRET=
# PASSWORD=
# USER_AGENT=redarc/1.0
# REDDIT_USERNAME=
# INDEX_DELAY=300
# SUBREDDITS=
# FETCH_DELAY=43200
# NUM_THREADS=25
